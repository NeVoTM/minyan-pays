generator client {
  provider = "prisma-client-js"
}

// SQLite by default for zero-setup local dev.
// For free cloud Postgres (Neon): set provider to "postgresql" and DATABASE_URL — see docs/FREE_DATABASE_NEON.md
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum PunchStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum BonusRecipient {
  SELF
  WIFE
}

model User {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  firstName        String
  lastName         String
  phone            String           @unique
  pinHash          String
  attendanceCode   String           @unique
  role             Role             @default(MEMBER)
  isMarried        Boolean          @default(false)
  zellePhone       String?
  wifeZellePhone   String?
  bonusRecipient   BonusRecipient   @default(WIFE)
  addressLine1     String?
  addressLine2     String?
  city             String?
  stateRegion      String?
  postalCode       String?
  email            String?
  spousePhone      String?
  spouseEmail      String?
  paypalAccount    String?
  achRoutingNumber String?
  achAccountNumber String?
  isApproved       Boolean          @default(true)
  attendances      Attendance[]
  weeklyPayouts    WeeklyPayout[]
}

model AppSettings {
  id               String @id @default("singleton")
  synagogueName    String @default("Dovrey Evrit")
  rabbiBanner      String?
  firstNineCents   Int    @default(1500)
  weeklyBonusCents Int    @default(3000)
  firstNineSlots   Int    @default(9)
  minReserveCents  Int    @default(0)
  timezone         String @default("America/New_York")
}

/** Cached US ZIP lookups (filled from public API on first request). */
model ZipCache {
  zip   String   @id
  city  String
  state String
  fetchedAt DateTime @default(now())
}

model Treasury {
  id             String  @id @default("singleton")
  balanceCents   Int     @default(0)
  systemLocked   Boolean @default(false)
}

model MinyanSession {
  id           String       @id @default(cuid())
  createdAt    DateTime     @default(now())
  dateKey      String       @unique
  status       String       @default("OPEN")
  attendances  Attendance[]
}

model Attendance {
  id                  String      @id @default(cuid())
  createdAt           DateTime    @default(now())
  sessionId           String
  session             MinyanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId              String
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  punchInAt           DateTime
  punchInStatus       PunchStatus @default(PENDING)
  punchInConfirmedAt  DateTime?
  punchOutAt          DateTime?

  @@unique([userId, sessionId])
}

model WeeklyPayout {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekKey     String
  amountCents Int
  paidAt      DateTime?
  notes       String?

  @@unique([userId, weekKey])
}
