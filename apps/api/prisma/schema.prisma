generator client {
  provider = "prisma-client-js"
}

// PostgreSQL everywhere (local Docker/Neon/Render). See SETUP.md and docs/FREE_DATABASE_NEON.md.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum PunchStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum BonusRecipient {
  SELF
  WIFE
}

enum OrganizationKind {
  SYNAGOGUE
  STUDY_HALL
}

enum MemberLedgerType {
  EARNED
  PAID
  DONATED
}

enum CashoutRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Organization {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  slug             String           @unique
  name             String
  kind             OrganizationKind @default(SYNAGOGUE)
  synagogueName    String
  locationAddress  String?
  locationPhone    String?
  locationEmail    String?
  locationWebsite  String?
  rabbiName        String?
  rabbiAddress     String?
  rabbiPhone       String?
  rabbiEmail       String?
  rabbiBanner      String?
  firstNineCents   Int              @default(1500)
  weeklyBonusCents Int              @default(3000)
  firstNineSlots   Int              @default(9)
  minReserveCents  Int              @default(0)
  timezone         String           @default("America/New_York")
  defaultLocale    String           @default("he")
  adminPasswordHash String?
  /** Optional; if null, rabbi login falls back to admin password (env or adminPasswordHash). */
  rabbiPasswordHash String?

  users          User[]
  rabbis         Rabbi[]
  minyanSessions MinyanSession[]
  treasury       Treasury?
  charities      Charity[]
  cashoutRequests CashoutRequest[]
  ledgerEntries  MemberLedgerEntry[]
}

model Rabbi {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  city           String?
  stateRegion    String?
  postalCode     String?
  phone          String?
  email          String?

  @@index([organizationId, name])
}

model User {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  phone            String
  pinHash          String
  attendanceCode   String
  role             Role             @default(MEMBER)
  isMarried        Boolean          @default(false)
  zellePhone       String?
  wifeZellePhone   String?
  bonusRecipient   BonusRecipient   @default(WIFE)
  addressLine1     String?
  addressLine2     String?
  city             String?
  stateRegion      String?
  postalCode       String?
  email            String?
  spousePhone      String?
  spouseEmail      String?
  paypalAccount    String?
  achRoutingNumber String?
  achAccountNumber String?
  isApproved       Boolean          @default(true)
  attendances      Attendance[]
  weeklyPayouts    WeeklyPayout[]
  ledgerEntries    MemberLedgerEntry[]
  changeCodes      MemberChangeCode[]
  cashoutRequests  CashoutRequest[]

  @@unique([organizationId, phone])
  @@unique([organizationId, attendanceCode])
}

model Charity {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  website        String?
  description    String?
  isActive       Boolean       @default(true)
  donations      MemberLedgerEntry[]

  @@index([organizationId, isActive])
  @@unique([organizationId, name])
}

model MemberLedgerEntry {
  id             String           @id @default(cuid())
  createdAt      DateTime         @default(now())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           MemberLedgerType
  amountCents    Int
  weekKey        String?
  note           String?
  charityId      String?
  charity        Charity?         @relation(fields: [charityId], references: [id], onDelete: SetNull)
  createdByRole  String?

  @@index([organizationId, userId, type, createdAt])
  @@unique([userId, weekKey, type])
}

model CashoutRequest {
  id             String              @id @default(cuid())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents    Int
  status         CashoutRequestStatus @default(PENDING)
  paidAt         DateTime?
  note           String?

  @@index([organizationId, userId, status, createdAt])
}

model MemberChangeCode {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose     String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?

  @@index([userId, purpose, expiresAt])
}

model Treasury {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  balanceCents   Int          @default(0)
  systemLocked   Boolean      @default(false)
}

/** Cached US ZIP lookups (filled from public API on first request). */
model ZipCache {
  zip       String   @id
  city      String
  state     String
  fetchedAt DateTime @default(now())
}

model MinyanSession {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dateKey        String
  status         String        @default("OPEN")
  attendances    Attendance[]

  @@unique([organizationId, dateKey])
}

model Attendance {
  id                 String        @id @default(cuid())
  createdAt          DateTime      @default(now())
  sessionId          String
  session            MinyanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  punchInAt          DateTime
  punchInStatus      PunchStatus   @default(PENDING)
  punchInConfirmedAt DateTime?
  punchOutAt         DateTime?

  @@unique([userId, sessionId])
}

model WeeklyPayout {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekKey     String
  amountCents Int
  paidAt      DateTime?
  notes       String?

  @@unique([userId, weekKey])
}
