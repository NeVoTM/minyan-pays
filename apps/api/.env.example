# Prisma uses PostgreSQL. Pick one:

# Local Docker (repo root: docker compose up -d) — port 5432:
# DATABASE_URL="postgresql://minyan:minyan@localhost:5432/minyan_pays"

# Local embedded Postgres (no Docker — npm run db:local from repo root) — port 5433:
DATABASE_URL="postgresql://minyan:minyan@127.0.0.1:5433/minyan_pays"

# Free cloud Postgres (Neon — see docs/FREE_DATABASE_NEON.md):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Render / other managed Postgres:
# DATABASE_URL="postgresql://..."

JWT_SECRET=change_me_before_deploy
# Optional: overrides built-in default bootstrap admin password (11213Aron) when Organization.adminPasswordHash is null.
# ADMIN_BOOTSTRAP_PASSWORD=
# Legacy: also used as bootstrap if ADMIN_BOOTSTRAP_PASSWORD unset.
# ADMIN_PASSWORD=
# Used only when Organization.rabbiPasswordHash is not set (per-org rabbi password is preferred).
RABBI_PASSWORD=change_me_before_deploy
WEB_ORIGIN=https://minyanpays.com
PORT=3001

# Profile SMS verification: set Twilio on production so “Send code” delivers a real text.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+15551234567
#
# Until Twilio is set: non-production builds echo the code in JSON; on production you can temporarily set:
# MEMBER_VERIFICATION_ECHO_CODE=1

DEFAULT_TIMEZONE="America/New_York"
