# Copy to `.env` (repo root) for agent/deploy tooling, and/or `apps/api/.env` for local API dev.

# Render (deploy automation — Dashboard → Account Settings → API Keys)
# For Cursor Cloud Agent: paste the key in repo root `.env` OR Cursor workspace secrets.
# For iPhone/GitHub only: use repository secret RENDER_API_KEY and run Actions → "Render API deploy".
# RENDER_API_KEY=
# RENDER_API_SERVICE_ID=srv-d7pbfg8sfn5c73de2q00   # minyan-pays-api (optional GitHub variable)
# RENDER_POSTGRES_SERVICE_ID=dpg-d7p9c23rjlhs73et01g0-a   # minyan-pays-db

DATABASE_URL="postgresql://minyan:minyan_dev@localhost:5432/minyan_pays?schema=public"

# Rabbi / admin login (change in production)
ADMIN_PASSWORD="change-me-strong-password"

# JWT signing (generate: openssl rand -base64 32)
JWT_SECRET="dev-only-change-in-production-use-openssl-rand-base64-32"

# CORS: Vite dev server
WEB_ORIGIN="http://localhost:5173"
